# Copy to .env and fill in values. Never commit .env.

# LLM (Step 3)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Stock imagery (Step 4)
PEXELS_API_KEY=

# FFmpeg (Step 6) — optional if ffmpeg is already on PATH
# FFMPEG_PATH=C:\Users\you\AppData\Local\Microsoft\WinGet\Packages\...\bin\ffmpeg.exe
# FFPROBE_PATH=C:\Users\you\AppData\Local\Microsoft\WinGet\Packages\...\bin\ffprobe.exe

# YouTube OAuth (Step 9) — paths relative to project root
YOUTUBE_CLIENT_SECRETS_FILE=credentials/client_secret.json
YOUTUBE_TOKEN_FILE=credentials/token.json
# YOUTUBE_PRIVACY_STATUS=unlisted

# Optional: Telegram notifications (Step 12)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: n8n HTTP trigger (Step 13)
TRIGGER_HOST=127.0.0.1
TRIGGER_PORT=8765
TRIGGER_API_KEY=

# Optional: n8n REST API + MCP (Cursor agent access)
N8N_API_URL=http://localhost:5678
N8N_API_KEY=
N8N_MCP_TOKEN=
